rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requester is an admin
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    // Contacts: anyone can submit (public write), only admin can read/manage
    match /contacts/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Contents: anyone can read, only admin can write
    match /contents/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings (program, tentang): anyone can read, only admin can write
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users: users can read/write their own doc; admin can read/write all
    match /users/{uid} {
      allow create: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow update: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }

    // SCRI-36: questions and scoring are public-read, admin-write
    match /scri_questions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /scri_scoring/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // SCRI results: authenticated users can create and read their own results; admin can read all
    match /scri_results/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Progress: users manage their own progress document
    match /progress/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if isAdmin();
    }
  }
}
